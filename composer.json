{
    "name": "vulcanphp/hyper",
    "type": "project",
    "description": "Sweet and MVT Based Php Tiny Web Framework",
    "keywords": ["vulcanphp", "hyper", "mvt", "web framework", "php framework"],
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "vulcanphp/hyper-core": "^1.0"
    },
    "authors": [
        {
            "name": "Shahin Moyshan",
            "email": "shahin.moyshan2@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "app\\": "./app",
            "models\\": "./app/models",
            "views\\": "./app/views"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
